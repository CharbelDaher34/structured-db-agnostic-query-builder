# Example environment configuration for structured-query-builder.
# Copy to .env, fill in the values you need, and run.
#
# The library reads everything via os.getenv(); nothing here is mandatory —
# only set the vars for the LLM provider and data source you're actually using.


# ============================================================================
# LLM provider
# ============================================================================
# Pick exactly one provider and set the matching API key.
# LLM_PROVIDER defaults to "openai" when unset.

LLM_PROVIDER=openai                       # openai | anthropic | google | openai-compatible
LLM_MODEL=gpt-4.1                         # provider-specific model name

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=sk-...

# --- Anthropic -------------------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini ---------------------------------------------------------
# LLM_PROVIDER=google
# LLM_MODEL=gemini-1.5-pro
# GOOGLE_API_KEY=...                      # GEMINI_API_KEY is accepted as an alias

# --- OpenAI-compatible (Ollama, vLLM, Azure OpenAI, …) ---------------------
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=qwen3:8b
# LLM_BASE_URL=http://localhost:11434     # /v1 suffix is appended automatically
# OPENAI_API_KEY=ollama                   # optional — Ollama accepts any value


# ============================================================================
# Data source — set the block for the adapter you're using
# ============================================================================

# --- MongoDB ---------------------------------------------------------------
# MONGO_URI=mongodb://user:password@host:27017/?authSource=admin
# MONGO_DATABASE=your_database
# MONGO_COLLECTION=your_collection
# MONGO_SAMPLE_SIZE=1000

# --- Elasticsearch ---------------------------------------------------------
# ES_HOST=http://localhost:9200
# ES_INDEX=your_index

# --- SQL (SQLAlchemy / SQLModel) -------------------------------------------
# Full SQLAlchemy URL — picks the dialect from the scheme.
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/your_database
# DATABASE_URL=mysql+pymysql://user:password@host:3306/your_database
# DATABASE_URL=sqlite:///path/to/your.db


# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
